{
    "compilerOptions": {
        "baseUrl": ".",
        "types": [ "@citizenfx/client", "@types/node" ],
        "removeComments": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "allowJs": true,
        "module": "ESNext",
        "target": "ESNext",
        "allowSyntheticDefaultImports": true,
        "declaration": false
    }
}