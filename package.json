    "@types/react-dom": "^18.0.1",
    "@vitejs/plugin-react": "^1.3.1",
    "remove-files-webpack-plugin": "^1.5.0",
    "ts-loader": "^9.2.8",
    "typescript": "^4.6.3",
    "vite": "^2.9.5",
    "webpack": "^5.72.0",
    "webpack-cli": "^4.9.2"
  },
  "dependencies": {
